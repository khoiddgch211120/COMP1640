# Frontend Environment Variables

# Backend API Base URL (WebSocket URL will be derived from this)
VITE_API_BASE_URL=http://api.antitt.io.vn

# Optional: Direct WebSocket URL (if different from auto-calculated)
# VITE_WS_BASE_URL=ws://localhost:8080

# Environment
VITE_ENV=development

# Optional: Enable verbose logging
# VITE_DEBUG=true
